# ============================================================
# equity_app — environment configuration template
# Copy to `.env` and fill in. ALL variables are optional unless marked
# REQUIRED — defaults live in core/constants.py + core/config.py.
# ============================================================

# ---------- API keys ----------
# Local-dev workflow: copy this file to `.env` (gitignored), or put the
# same keys in ~/.streamlit/secrets.toml (preferred). On Streamlit Cloud,
# use App Settings → Secrets pane. Never paste keys into source files.

# REQUIRED for 10y financials via FMP. Free tier at:
#   https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# SEC EDGAR — no key, but their usage policy requires identifying yourself
# in the User-Agent header. Format: "Your Name your_email@example.com".
SEC_USER_AGENT=

# Optional. FRED endpoints work without a key but the key avoids rate limits.
FRED_API_KEY=

# Optional — Marketaux news with per-ticker sentiment.
MARKETAUX_API_KEY=

# Optional — Finnhub quotes / insider transactions / news.
FINNHUB_API_KEY=

# Optional — Anthropic API for AI investment thesis (powers the auto-thesis tab).
ANTHROPIC_API_KEY=

# Optional fallback provider.
ALPHA_VANTAGE_KEY=

# ---------- Cache ----------
# disk = single-user (Streamlit Community Cloud, local dev)
# redis = multi-user / scaled deployments
CACHE_BACKEND=disk
REDIS_URL=redis://localhost:6379
CACHE_TTL_HOURS=24

# Optional override of the on-disk cache directory (default: equity_app/.cache)
# CACHE_DIR=/var/cache/equity_app

# ---------- Watchlist persistence (page 4) ----------
# WATCHLIST_DB_PATH=/var/lib/equity_app/watchlist.db

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---------- Rate limiting ----------
FMP_CALLS_PER_MINUTE=250
FINVIZ_DELAY_SECONDS=1.0
FRED_CALLS_PER_MINUTE=120
YFINANCE_DELAY_SECONDS=0.5

# ---------- Application defaults ----------
DEFAULT_REFRESH_INTERVAL=5
DEFAULT_RISK_FREE=0.045
DEFAULT_ERP=0.055
DEFAULT_TERMINAL_GROWTH=0.025

# ---------- Provider fallback chain ----------
# Tried in order. First successful response wins; if all fail,
# TickerNotFoundError is raised with the literal user-facing message.
PROVIDER_PRIORITY=fmp,finviz,yfinance
